{
  "colors": {
    "primary": "#1a3a52",
    "secondary": "#4a5f7f",
    "accent": "#2d7a9e",
    "bg": "#f8f9fa",
    "surface": "#ffffff",
    "text": "#2c3e50",
    "muted": "#8b95a5",
    "success": "#2d8659",
    "danger": "#a83232"
